---
import "../styles/global.css";
import { Analyzer } from "../components/Analyzer";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Drop in a GPX file and get a route map, elevation profile, splits, and pace zones. Parsed entirely in your browser, never uploaded."
    />
    <title>GPX Analyzer</title>
  </head>
  <body class="min-h-screen">
    <main class="mx-auto flex min-h-screen max-w-3xl flex-col items-center justify-center gap-6 px-6 text-center">
      <p class="text-sm font-medium uppercase tracking-widest text-primary">
        GPX Analyzer
      </p>
      <h1 class="text-balance text-4xl font-bold sm:text-5xl">
        Drop a <span class="text-primary">.gpx</span> file. See the whole run.
      </h1>
      <p class="max-w-xl text-balance text-on-surface-variant">
        Route map, elevation profile, distance and gain, pace zones, splits, and
        heart-rate when it's there. Everything runs in your browser &mdash; the
        file never leaves your device.
      </p>
      <div class="w-full">
        <Analyzer client:only="react" />
      </div>
    </main>
  </body>
</html>
